# ============================================================
# Automated Resume Screener — Environment Variables
#
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================

# --- Database ---
# Local development (Docker Compose):
DATABASE_URL=postgresql://ars_leandro:ars_leandropass@localhost:5432/ars_dev

# Test database (separate DB — never the same as DATABASE_URL):
TEST_DATABASE_URL=postgresql://ars_user:ars_password@localhost:5432/ars_test

# --- JWT Authentication ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=HWcoJv5t8FNei2MJMzIhejx35V8vdpJ3icdL23KOmvQ
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- File Storage ---
STORAGE_PATH=./storage
MAX_FILE_SIZE_MB=10
FILE_RETENTION_DAYS=30

# --- Application ---
APP_ENV=development         # development | production
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# CORS (for production, list allowed frontend URLs)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# NLP Model (spaCy — automatically downloaded by Dockerfile)
SPACY_MODEL=en_core_web_sm